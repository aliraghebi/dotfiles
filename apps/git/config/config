; vim: set ft=gitconfig:

[core]
  excludesfile = ~/.config/git/ignore
  editor = nvim

[pull]
  rebase = true

[credential]
  helper = cache

[merge]
  tool = vimdiff
  # conflictstyle = diff3

[mergetool]
  prompt = true

[mergetool "vimdiff"]
  cmd = nvim -d $BASE $LOCAL $REMOTE $MERGED -c 'wincmd w' -c 'wincmd J'

[init]
  defaultBranch = main

[user]
  name = Ali Raghebi
  email = aliraghebiii@gmail.com

[fetch]
  parallel = 0

[diff "exif"]
	textconv = exiftool

[diff "sqlite3"]
    binary = true
    textconv = "echo .dump | sqlite3"

[push]
	autoSetupRemote = true